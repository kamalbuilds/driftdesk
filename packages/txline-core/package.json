{
  "name": "@txline/core",
  "version": "0.1.0",
  "description": "Shared TxLINE client: guest auth, devnet subscribe/activate/faucet, fixtures/odds/scores, SSE streaming, historical replay, implied-probability math, and on-chain validation helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./src/index.ts", "types": "./src/index.ts" },
    "./replay": { "import": "./src/replay/index.ts" },
    "./math": { "import": "./src/math/index.ts" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "doctor": "tsx src/cli/doctor.ts",
    "activate": "tsx src/cli/activate.ts",
    "pull": "tsx src/cli/pull.ts",
    "settle": "tsx src/cli/settle.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
